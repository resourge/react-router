{
	"name": "@resourge/react-router",
	"version": "1.30.3",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"react-native": "./dist/index.native.js",
			"types": {
				"react-native": "./dist/index.native.d.ts",
				"default": "./dist/index.d.ts"
			},
			"default": "./dist/index.js"
		},
		"./vite": {
			"types": "./dist/vite/vite.d.ts",
			"default": "./dist/vite/vite.js"
		},
		"./mobile": {
			"types": "./dist/index.native.d.ts",
			"default": "./dist/index.native.js"
		}
	},
	"typesVersions": {
		"*": {
			"index.d.ts": [
				"./dist/index.d.ts"
			],
			"vite": [
				"./dist/vite/vite.d.ts"
			],
			"mobile": [
				"./dist/index.native.d.ts"
			]
		}
	},
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"react",
		"hooks",
		"router",
		"URLPattern",
		"navigation",
		"typescript",
		"react-hooks",
		"react-router",
		"react-native"
	],
	"files": [
		"dist"
	],
	"author": "resourge",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/resourge/react-router.git"
	},
	"scripts": {
		"commit": "git pull && git add . && git-cz",
		"lint": "eslint \"./src/**/*.{ts,tsx}\"",
		"lint:prod": "cross-env NODE_ENV=production npm run lint",
		"dev": "vite",
		"build": "vite build -c vite.config.ts && vite build -c vite.viteconfig.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"semantic-release": "semantic-release"
	},
	"peerDependencies": {
		"@resourge/history-store": "*",
		"react": ">=17.0.0",
		"react-native": "*",
		"react-native-safe-area-context": "*",
		"react-native-screens": "*",
		"react-native-url-polyfill": "*"
	},
	"peerDependenciesMeta": {
		"react-native": {
			"optional": true
		},
		"react-native-safe-area-context": {
			"optional": true
		},
		"react-native-screens": {
			"optional": true
		},
		"react-native-url-polyfill": {
			"optional": true
		}
	},
	"dependencies": {
		"@babel/preset-typescript": "^7.28.5",
		"ansi-colors": "^4.1.3",
		"html-minifier-terser": "^7.2.0",
		"import-sync": "^2.2.6",
		"node-html-parser": "^7.1.0",
		"tsconfig-paths": "^4.2.0",
		"urlpattern-polyfill": "^10.1.0"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@fastify/deepmerge": "^3.2.1",
		"@resourge/history-store": "^1.4.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/babel__core": "^7.20.5",
		"@types/html-minifier-terser": "^7.0.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.5",
		"app-root-path": "^3.1.0",
		"cross-env": "^10.1.0",
		"cz-conventional-changelog": "^3.3.0",
		"eslint-config-resourge": "^1.8.2",
		"glob": "^13.0.6",
		"jsdom": "^29.1.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-native": "^0.85.2",
		"react-native-safe-area-context": "^5.7.0",
		"react-native-screens": "^4.24.0",
		"react-native-url-polyfill": "^3.0.0",
		"semantic-release": "^25.0.3",
		"typescript": "^5.9.3",
		"vite": "^8.0.10",
		"vite-plugin-banner": "^0.8.1",
		"vite-plugin-checker": "^0.13.0",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.1.5"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
